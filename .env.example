# Copy this file to `.env` (in the repo root) and fill in the values.
# The deploy.ps1 script will write a .env for you automatically.
#
# Lines starting with # are comments. Quotes around values are optional and stripped.

SERVICEBUS_CONNECTION_STRING=Endpoint=sb://<namespace>.servicebus.windows.net/;SharedAccessKeyName=RootManageSharedAccessKey;SharedAccessKey=<key>
SERVICEBUS_NAMESPACE=<namespace>.servicebus.windows.net
